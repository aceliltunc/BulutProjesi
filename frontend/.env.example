# Lokal: npm run dev (Vite) — API'ye dogrudan baglanti
#VITE_API_BASE_URL=http://localhost:8080

# Bos veya satiri sil: `npm run build` sonrasi ayni origin (nginx imaji API'yi proxy eder; Azure/docker-compose)
#VITE_API_BASE_URL=

# Iki ayrin public FQDN (sadece API) kullanacaksaniz, frontend imajini soyle uretin:
# docker build --build-arg VITE_API_BASE_URL=https://<api-app>.azurecontainerapps.io -t frontend:prod ./frontend
